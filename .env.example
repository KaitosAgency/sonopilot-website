# Copier vers .env.local et remplir les valeurs (ne jamais committer .env.local).

# URL canonique du site (SEO, sitemap) — ex. https://www.sonopilot.com
NEXT_PUBLIC_SITE_URL=

# URL de l’app (CTA inscription / connexion) — ex. https://www.app.sonopilot.com
NEXT_PUBLIC_APP_URL=

# Google Analytics 4 — ID de mesure (flux Web), ex. G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console — jeton de la balise meta name="google-site-verification"
GOOGLE_SITE_VERIFICATION=

# Bandeau stats sur la landing — projet Supabase (clé anon uniquement ; pas de service_role)
# Valeurs : dashboard Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
